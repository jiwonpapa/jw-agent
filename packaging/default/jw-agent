# Public HTTPS remains disabled when this value is empty.
JW_AGENT_PUBLIC_HOST=
# Comma-separated public origin IPs. Required only for guided Certbot issuance.
JW_AGENT_PUBLIC_ADDRESSES=
JW_EDGE_LISTEN_ADDRESS=0.0.0.0:9443
JW_EDGE_CERTIFICATE=/etc/jw-agent/edge/server.crt
JW_EDGE_PRIVATE_KEY=/etc/jw-agent/edge/server.key
JW_EDGE_UPSTREAM_SOCKET=/run/jw-agent-proxy/agentd.sock
JW_EDGE_READY_FILE=/run/jw-agent-edge/ready
JW_EDGE_READY_SOCKET=/run/jw-agent-edge/ready.sock
JW_AGENT_RECOVERY_ADDRESS=127.0.0.1:8787
JW_AGENT_RECOVERY_ORIGIN=http://127.0.0.1:8787
JW_AGENT_PROXY_SOCKET=/run/jw-agent-proxy/agentd.sock
JW_AGENT_AUTH_SOCKET=/run/jw-agent/authd.sock
JW_AGENT_OPS_SOCKET=/run/jw-agent/opsd.sock
JW_AGENT_DATABASE=/var/lib/jw-agent/agentd/agentd.sqlite3
JW_AGENT_WEB_ROOT=/usr/share/jw-agent/web
JW_OPSD_SOCKET=/run/jw-agent/opsd.sock
