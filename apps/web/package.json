{
  "name": "@jw-agent/web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "api:generate": "openapi-typescript ../../api/openapi.json -o src/shared/api/generated/schema.d.ts",
    "routes:generate": "tsr generate",
    "css:build": "tailwindcss -i ./src/styles/theme.css -o ./src/styles/generated.css",
    "css:watch": "tailwindcss -i ./src/styles/theme.css -o ./src/styles/generated.css --watch",
    "dev": "bun run css:build && bun run routes:generate && vite --host 127.0.0.1",
    "typecheck": "bun run routes:generate && tsc -b",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "build": "bun run css:build && bun run routes:generate && vite build"
  },
  "dependencies": {
    "@codemirror/commands": "6.10.4",
    "@codemirror/language": "6.12.4",
    "@codemirror/legacy-modes": "6.5.3",
    "@codemirror/merge": "6.12.2",
    "@codemirror/state": "6.7.1",
    "@codemirror/view": "6.43.6",
    "@radix-ui/react-dialog": "1.1.20",
    "@radix-ui/react-slot": "1.3.0",
    "@tanstack/react-query": "5.101.3",
    "@tanstack/react-router": "1.170.18",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.25.0",
    "openapi-fetch": "0.17.0",
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/cli": "4.3.3",
    "@tanstack/router-cli": "1.167.21",
    "@tanstack/router-plugin": "1.168.23",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "openapi-typescript": "7.13.0",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "overrides": {
    "js-yaml": "4.3.0"
  }
}
